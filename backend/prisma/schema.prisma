generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────── ENUMS ────────────────────────

enum AdminRole {
  super_admin
  catalogue_mgr
  order_mgr
  support_agent
}

enum StaffStatus {
  active
  suspended
}

enum UserStatus {
  active
  blocked
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum FCTier {
  classic
  silver
  gold
  platinum
}

enum ProductStatus {
  active
  draft
  out_of_stock
  deleted
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  returned
}

enum PaymentMethod {
  razorpay_card
  razorpay_upi
  razorpay_netbanking
  razorpay_wallet
  cod
  fc_points
  store_credit
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
  partially_refunded
}

enum ReturnStatus {
  pending
  approved
  rejected
}

enum RefundMethod {
  original
  store_credit
  fc_points
}

enum CouponType {
  percent
  flat
  free_delivery
  buy_x_get_y
}

enum CouponApplicableTo {
  all
  first_citizens
  new_users
}

enum CouponStatus {
  active
  inactive
}

enum BannerPage {
  homepage
  plp
  pdp
  cart
  all
}

enum BannerPosition {
  hero_carousel
  announcement_bar
  section_banner
  popup
}

enum BannerStatus {
  active
  scheduled
  expired
}

enum InventoryStatus {
  healthy
  low
  out_of_stock
}

enum PointTransactionType {
  earned_purchase
  earned_bonus
  redeemed
  expired
  adjusted_credit
  adjusted_debit
  refund_credit
}

enum ReviewStatus {
  pending
  approved
  rejected
}

// ──────────────────── USERS ────────────────────────

model User {
  id              String      @id @default(cuid())
  firebaseUid     String      @unique
  email           String      @unique
  mobile          String?     @unique
  name            String
  gender          Gender?
  birthday        DateTime?
  avatarUrl       String?
  status          UserStatus  @default(active)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  addresses       Address[]
  orders          Order[]
  cart            Cart?
  wishlistItems   WishlistItem[]
  reviews         Review[]
  returns         Return[]
  fcAccount       FirstCitizenAccount?
  savedCards      SavedCard[]

  @@map("users")
}

model Address {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?
  fullName      String
  mobile        String
  line1         String
  line2         String?
  city          String
  state         String
  pincode       String
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]

  @@map("addresses")
}

model SavedCard {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  razorpayToken String
  last4         String
  network       String
  expiryMonth   Int
  expiryYear    Int
  createdAt     DateTime  @default(now())

  @@map("saved_cards")
}

// ──────────────────── STAFF ────────────────────────

model StaffMember {
  id            String      @id @default(cuid())
  firebaseUid   String?     @unique
  name          String
  email         String      @unique
  role          AdminRole
  status        StaffStatus @default(active)
  joinedDate    DateTime    @default(now())
  lastActive    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  auditLogs     AuditLog[]

  @@map("staff_members")
}

model AuditLog {
  id          String      @id @default(cuid())
  staffId     String
  staff       StaffMember @relation(fields: [staffId], references: [id])
  action      String
  module      String
  recordId    String
  details     String
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

// ──────────────────── CATALOGUE ────────────────────

model Category {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  parentId    String?
  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")
  imageUrl    String?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  products    Product[]

  @@map("categories")
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logoUrl     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("brands")
}

model Product {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String?
  brand         Brand           @relation(fields: [brandId], references: [id])
  brandId       String
  category      Category        @relation(fields: [categoryId], references: [id])
  categoryId    String
  mrp           Decimal         @db.Decimal(10, 2)
  sellingPrice  Decimal         @db.Decimal(10, 2)
  thumbnailUrl  String?
  images        String[]
  tags          String[]
  status        ProductStatus   @default(draft)
  algoliaId     String?
  isFeatured    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  variants      ProductVariant[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@map("products")
}

model ProductVariant {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String          @unique
  size        String
  colour      String
  stock       Int             @default(0)
  reorderLevel Int            @default(10)
  status      InventoryStatus @default(healthy)
  updatedAt   DateTime        @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("product_variants")
}

// ──────────────────── CART ─────────────────────────

model Cart {
  id              String      @id @default(cuid())
  userId          String?     @unique
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String?     @unique
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  fcPointsApplied Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           CartItem[]

  @@map("carts")
}

model CartItem {
  id          String          @id @default(cuid())
  cartId      String
  cart        Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String
  variant     ProductVariant  @relation(fields: [variantId], references: [id])
  quantity    Int
  addedAt     DateTime        @default(now())

  @@unique([cartId, variantId])
  @@map("cart_items")
}

model WishlistItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt     DateTime  @default(now())

  @@unique([userId, productId])
  @@map("wishlist_items")
}

// ──────────────────── ORDERS ───────────────────────

model Order {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  addressId         String
  address           Address       @relation(fields: [addressId], references: [id])
  status            OrderStatus   @default(pending)
  subtotal          Decimal       @db.Decimal(10, 2)
  discount          Decimal       @default(0) @db.Decimal(10, 2)
  fcPointsRedeemed  Int           @default(0)
  fcDiscount        Decimal       @default(0) @db.Decimal(10, 2)
  deliveryCharge    Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(pending)
  razorpayOrderId   String?
  razorpayPaymentId String?
  transactionId     String        @unique @default(cuid())
  couponId          String?
  coupon            Coupon?       @relation(fields: [couponId], references: [id])
  trackingNumber    String?
  courier           String?
  internalNote      String?
  fcPointsEarned    Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  items             OrderItem[]
  returns           Return[]
  shiprocketShipmentId String?

  @@map("orders")
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String
  variant     ProductVariant  @relation(fields: [variantId], references: [id])
  productName String
  size        String
  colour      String
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  imageUrl    String?

  @@map("order_items")
}

// ──────────────────── PAYMENTS ─────────────────────

model Payment {
  id                  String        @id @default(cuid())
  razorpayOrderId     String        @unique
  razorpayPaymentId   String?       @unique
  amount              Int
  currency            String        @default("INR")
  status              PaymentStatus @default(pending)
  refundId            String?
  refundAmount        Int?
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@map("payments")
}

// ──────────────────── RETURNS ──────────────────────

model Return {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  productName   String
  reason        String
  customerNote  String?
  photos        String[]
  refundAmount  Decimal       @db.Decimal(10, 2)
  refundMethod  RefundMethod  @default(original)
  status        ReturnStatus  @default(pending)
  rejectionNote String?
  requestedDate DateTime      @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("returns")
}

// ──────────────────── COUPONS ──────────────────────

model Coupon {
  id              String              @id @default(cuid())
  code            String              @unique
  type            CouponType
  value           Decimal             @db.Decimal(10, 2)
  minOrderValue   Decimal             @default(0) @db.Decimal(10, 2)
  usageCount      Int                 @default(0)
  usageLimit      Int
  userLimit       Int                 @default(1)
  startDate       DateTime
  expiry          DateTime
  applicableTo    CouponApplicableTo  @default(all)
  status          CouponStatus        @default(active)
  categories      String[]
  brands          String[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  carts           Cart[]
  orders          Order[]
  userUsages      CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String    @id @default(cuid())
  couponId  String
  coupon    Coupon    @relation(fields: [couponId], references: [id])
  userId    String
  orderId   String?
  usedAt    DateTime  @default(now())

  @@unique([couponId, userId, orderId])
  @@map("coupon_usages")
}

// ──────────────────── REVIEWS ──────────────────────

model Review {
  id          String        @id @default(cuid())
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  rating      Int
  title       String?
  body        String
  photos      String[]
  status      ReviewStatus  @default(pending)
  isVerified  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([productId, userId])
  @@map("reviews")
}

// ──────────────────── BANNERS / CMS ────────────────

model Banner {
  id              String          @id @default(cuid())
  name            String
  page            BannerPage
  position        BannerPosition
  desktopImage    String
  mobileImage     String
  headline        String?
  ctaLabel        String?
  ctaUrl          String?
  startDate       DateTime
  endDate         DateTime?
  evergreen       Boolean         @default(false)
  priority        Int             @default(0)
  status          BannerStatus    @default(scheduled)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("banners")
}

// ──────────────────── FIRST CITIZEN ────────────────

model FirstCitizenAccount {
  id                  String                @id @default(cuid())
  userId              String                @unique
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardNumber          String                @unique
  tier                FCTier                @default(classic)
  pointsBalance       Int                   @default(0)
  annualSpend         Decimal               @default(0) @db.Decimal(12, 2)
  pointsIssuedMTD     Int                   @default(0)
  pointsRedeemedMTD   Int                   @default(0)
  joinedDate          DateTime              @default(now())
  expiryDate          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  transactions        PointTransaction[]

  @@map("first_citizen_accounts")
}

model PointTransaction {
  id            String                @id @default(cuid())
  accountId     String
  account       FirstCitizenAccount   @relation(fields: [accountId], references: [id])
  type          PointTransactionType
  points        Int
  description   String
  orderId       String?
  expiresAt     DateTime?
  createdAt     DateTime              @default(now())

  @@map("point_transactions")
}

model FCTierRule {
  id          String    @id @default(cuid())
  tier        FCTier    @unique
  minSpend    Decimal   @db.Decimal(12, 2)
  pointsRate  Decimal   @db.Decimal(5, 2)
  updatedAt   DateTime  @updatedAt

  @@map("fc_tier_rules")
}

// ──────────────────── SEARCH ───────────────────────

model SearchSynonym {
  id          String    @id @default(cuid())
  objectId    String    @unique
  synonyms    String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("search_synonyms")
}
