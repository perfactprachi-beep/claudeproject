{
  "info": {
    "name": "Shoppers Stop MVP — Full API",
    "_postman_id": "shoppers-stop-mvp-api-v1",
    "description": "Complete REST API collection for Shoppers Stop MVP.\n\n**Base URL:** `http://localhost:4000`\n\n**Dev Auth (no Firebase):**\n- Any route: `Authorization: Bearer devtoken`\n- Admin role: add header `x-dev-role: super_admin` (or `catalogue_mgr`, `order_mgr`, `support_agent`)\n\n**Error Codes:** PRODUCT_NOT_FOUND | OUT_OF_STOCK | COUPON_EXPIRED | COUPON_INVALID | COUPON_MIN_ORDER_NOT_MET | PAYMENT_FAILED | PAYMENT_VERIFICATION_FAILED | ORDER_NOT_CANCELLABLE | RETURN_WINDOW_EXPIRED | INSUFFICIENT_FC_POINTS | TOKEN_EXPIRED | INSUFFICIENT_PERMISSIONS | VALIDATION_ERROR | RATE_LIMIT_EXCEEDED",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "devToken", "value": "devtoken", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "addressId", "value": "", "type": "string" },
    { "key": "variantId", "value": "", "type": "string" },
    { "key": "cartItemId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{devToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🟢 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api-docs", "host": ["{{baseUrl}}"], "path": ["api-docs"] }
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Verify Firebase Token",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-token", "host": ["{{baseUrl}}"], "path": ["api","auth","verify-token"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<firebase-id-token>\"\n}" }
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firebaseUid\": \"uid_123\",\n  \"name\": \"Prachi Shah\",\n  \"email\": \"prachi@example.com\",\n  \"mobile\": \"9876543210\",\n  \"gender\": \"female\",\n  \"birthday\": \"1995-06-15\"\n}" }
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/auth/admin/login", "host": ["{{baseUrl}}"], "path": ["api","auth","admin","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@shoppersstop.com\",\n  \"password\": \"Admin@123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "🛍️ Products (Storefront)",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/products?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api","products"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"},{"key":"category","value":"","disabled":true},{"key":"brand","value":"","disabled":true},{"key":"minPrice","value":"","disabled":true},{"key":"maxPrice","value":"","disabled":true},{"key":"sort","value":"featured","disabled":true},{"key":"q","value":"","disabled":true}] }
          }
        },
        {
          "name": "Get Product Detail",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","products","{{productId}}"] }
          }
        },
        {
          "name": "Get Product Reviews",
          "request": {
            "method": "GET", "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}/reviews?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api","products","{{productId}}","reviews"] }
          }
        },
        {
          "name": "Submit Review (auth required)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}/reviews", "host": ["{{baseUrl}}"], "path": ["api","products","{{productId}}","reviews"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"title\": \"Loved it!\",\n  \"body\": \"Great quality and perfect fit.\"\n}" }
          }
        }
      ]
    },
