# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173/admin

# ── PostgreSQL (Prisma) ──────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/shoppers_stop

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Firebase Admin SDK ───────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── AWS S3 ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
S3_BUCKET_NAME=shoppers-stop-assets
S3_BUCKET_URL=https://shoppers-stop-assets.s3.ap-south-1.amazonaws.com

# ── SendGrid ─────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@shoppersstop.com
SENDGRID_FROM_NAME=Shoppers Stop

# ── MSG91 ────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=SHPSTO
MSG91_OTP_TEMPLATE_ID=your-otp-template-id

# ── Algolia ──────────────────────────────────────────
ALGOLIA_APP_ID=YOUR_APP_ID
ALGOLIA_ADMIN_KEY=your-algolia-admin-api-key
ALGOLIA_SEARCH_KEY=your-algolia-search-only-key
ALGOLIA_INDEX_NAME=shoppers_stop_products

# ── Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Shiprocket ───────────────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external

# ── JWT / Session ────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
SESSION_SECRET=your-session-secret

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
